<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.user.audiobridge</string>
    <key>ProgramArguments</key>
    <array>
        <string>{{ pushtotalk_install_path }}</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardErrorPath</key>
    <string>/tmp/audiobridge.err</string>
    <key>StandardOutPath</key>
    <string>/tmp/audiobridge.out</string>
</dict>
</plist>
